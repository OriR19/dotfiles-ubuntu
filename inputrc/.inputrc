# ~/.inputrc configuration for better completion

# Enable colors for file types (if supported)
set colored-stats on
# Append char to indicate type (e.g. / for directory)
set visible-stats on
# Show all completions immediately (no double tab)
set show-all-if-ambiguous on
# Ignore case
set completion-ignore-case on
# Treat hyphens and underscores as equivalent
set completion-map-case on

# Note: 'page-completions off' can cause terminal flooding if there are many results.
# We leave it enabled (default) to show the "Display all X possibilities?" prompt.
# set page-completions off
